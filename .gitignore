# Claude Code — personal overrides (never commit real secrets here)
.claude/settings.local.json
CLAUDE.local.md

.DS_Store

# Local tooling
.venv/

# Python bytecode cache
__pycache__/
*.pyc

# Hook logs
.claude/logs/

# Runtime pipeline state (live state.json; committed demo is schemas/samples/state.sample.json)
.pipeline/

# Playwright / CV template iteration screenshots (repo root ./tmp)
tmp/
.playwright-mcp/

# Vacancy-oriented, per-offer generated configs (skill-specific CV YAMLs,
# config/cv/cv.[skill].[lang].yaml) — derived per vacancy, never hand-edited,
# never committed (keep directory tree via .gitkeep).
config/cv/*
!config/cv/.gitkeep

# Generated collective outputs (keep directory trees via .gitkeep)
output/cv/*
!output/cv/.gitkeep

# Also covers output/analysis/self-reflect-report.md (D-06/Phase 06 self-reflection
# analyzer output — verified via `git check-ignore` in 06-05-PLAN.md's Task 3).
output/analysis/*
!output/analysis/.gitkeep

output/artifacts/*
!output/artifacts/.gitkeep

output/offers/*
!output/offers/.gitkeep

output/research/*
!output/research/.gitkeep

output/vacancies/*
!output/vacancies/.gitkeep

output/logs/*
!output/logs/.gitkeep

# GSD execution logs (per-session tool-call/workflow telemetry written by
# .claude/hooks/gmj-execution-log*.sh) — churn every session, no reason to be
# version-controlled (keep directory tree via .gitkeep).
.planning/execution-logs/*
!.planning/execution-logs/.gitkeep

# sources/{artifacts,offers,analysis,research,vacancies}/ are intake-only in
# name but have historically leaked live pipeline-generated output (STRUCT-01
# floor per ROADMAP success criterion 1); keep these ignore blocks standing on
# their own even if the corresponding output/* block above were ever removed.
sources/artifacts/*
!sources/artifacts/.gitkeep

sources/offers/*
!sources/offers/.gitkeep

sources/analysis/*
!sources/analysis/.gitkeep

sources/research/*
!sources/research/.gitkeep

sources/vacancies/*
!sources/vacancies/.gitkeep

# Real PII map + denylist for scripts/publish/gmj_publish_mirror.sh — hold the
# real values from config/candidate.yaml; only the .sample templates ship.
scripts/publish/replacements.txt
scripts/publish/pii-denylist.txt

# Firecrawl credentials — real key never committed; .env.example ships the placeholder.
.env

# Next.js (web/) build surface — Phase 46 introduces the repo's first Node
# build step outside .claude/'s own tooling. web/node_modules/ can be
# hundreds of MB; web/.next/ and web/out/ (the static-export output, the
# direct publish source per Phase 46's Resolved Discretion Call #1) are
# fully regenerable from source. Do NOT add web/package-lock.json here — it
# must stay committed so CI's `npm ci` has a pinned lockfile.
web/node_modules/
web/.next/
web/out/
web/.env*.local
web/tsconfig.tsbuildinfo
