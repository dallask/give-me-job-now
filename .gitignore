# Claude Code — personal overrides (never commit real secrets here)
.claude/settings.local.json
CLAUDE.local.md

.DS_Store

# Local tooling
.venv/

# Python bytecode cache
__pycache__/
*.pyc

# Hook logs
.claude/logs/

# Runtime pipeline state (live state.json; committed demo is schemas/samples/state.sample.json)
.pipeline/

# Playwright / CV template iteration screenshots (repo root ./tmp)
tmp/
.playwright-mcp/

# Generated collective outputs (keep directory trees via .gitkeep)
output/cv/*
!output/cv/.gitkeep

output/analysis/*
!output/analysis/.gitkeep

output/artifacts/*
!output/artifacts/.gitkeep

output/offers/*
!output/offers/.gitkeep

output/research/*
!output/research/.gitkeep

output/vacancies/*
!output/vacancies/.gitkeep

output/logs/*
!output/logs/.gitkeep

# sources/artifacts/ is intake-only in name but has historically leaked live
# per-offer pipeline-draft output (STRUCT-01 floor); keep this ignore block
# standing on its own even if output/artifacts/* above were ever removed.
sources/artifacts/*
!sources/artifacts/.gitkeep

# Real PII map + denylist for scripts/publish/gmj_publish_mirror.sh — hold the
# real values from config/candidate.yaml; only the .sample templates ship.
scripts/publish/replacements.txt
scripts/publish/pii-denylist.txt
