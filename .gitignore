# Claude Code — personal overrides (never commit real secrets here)
.claude/settings.local.json
CLAUDE.local.md

.DS_Store

# Local tooling
.venv/

# Python bytecode cache
__pycache__/
*.pyc

# Hook logs
.claude/logs/

# Runtime pipeline state (live state.json; committed demo is schemas/samples/state.sample.json)
.pipeline/

# Playwright / CV template iteration screenshots (repo root ./tmp)
tmp/
.playwright-mcp/

# Generated collective outputs (keep directory trees via .gitkeep)
output/cv/*
!output/cv/.gitkeep

sources/analysis/*
!sources/analysis/.gitkeep

sources/research/*
!sources/research/.gitkeep

sources/vacancies/*
!sources/vacancies/.gitkeep

# Frozen offer-specs are generated by scripts/offers/gmj_freeze_offer.py; keep the
# raw + fielded draft fixtures tracked, ignore the generated *.offer-spec.json.
sources/offers/*
!sources/offers/.gitkeep
!sources/offers/sample-offer.txt
!sources/offers/sample-offer-draft.json

# Real PII map + denylist for scripts/publish/gmj_publish_mirror.sh — hold the
# real values from config/candidate.yaml; only the .sample templates ship.
scripts/publish/replacements.txt
scripts/publish/pii-denylist.txt
