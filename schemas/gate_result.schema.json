{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:give-me-job:schema:gate_result",
  "title": "gate_result envelope",
  "description": "Envelope for a quality-gate verdict emitted by truth-verifier / fit-evaluator. Pins kind via const and reuses the shared agent_result_v1 base. Gate A content names the offending claims that fail truth verification (TRUTH-03); Gate B/C extend the same shell in Phase 6.",
  "type": "object",
  "$defs": {
    "offending_claim": {
      "type": "object",
      "description": "A single claim that failed truth verification. claim_index points at the offending item in the draft claims array; rule_violated names the truth rule broken; offending_span is the dotted/indexed source path. Self-contained: additionalProperties:false is scoped to this object ONLY.",
      "properties": {
        "claim_index": {
          "type": "integer",
          "minimum": 0
        },
        "rule_violated": {
          "type": "string",
          "enum": [
            "unresolved_span",
            "scope_inflation",
            "numeric_invention",
            "cross_entry_merge"
          ]
        },
        "offending_span": {
          "type": "string"
        }
      },
      "required": ["claim_index", "rule_violated", "offending_span"],
      "additionalProperties": false
    },
    "gate_a_content": {
      "type": "object",
      "description": "Gate A (truth) verdict body. gate discriminates the gate variant; verdict is the pass/fail decision; offending_claims lists the failing claims (empty on pass). Self-contained: additionalProperties:false is scoped to this object ONLY, never the allOf envelope. offending_claims items use the ABSOLUTE URN ref so a bare content sub-doc validates as a standalone root.",
      "properties": {
        "gate": {
          "const": "A"
        },
        "verdict": {
          "type": "string",
          "enum": ["pass", "fail"]
        },
        "offending_claims": {
          "type": "array",
          "items": { "$ref": "urn:give-me-job:schema:gate_result#/$defs/offending_claim" }
        }
      },
      "required": ["gate", "verdict", "offending_claims"],
      "additionalProperties": false
    },
    "missing_must_have": {
      "type": "object",
      "description": "A single offer must-have not covered by the draft claims. id is the stable index ID (e.g. \"mh-2\"); text is the must-have string. Self-contained: additionalProperties:false is scoped to this object ONLY.",
      "properties": {
        "id": {
          "type": "string"
        },
        "text": {
          "type": "string"
        }
      },
      "required": ["id", "text"],
      "additionalProperties": false
    },
    "gate_b_content": {
      "type": "object",
      "description": "Gate B (target-fit) verdict body. gate discriminates the variant; verdict is the coverage-gated pass/fail; coverage carries the deterministic counts; the secondary sub-scores and the structured why are advisory context. Self-contained: additionalProperties:false is scoped to this object ONLY, never the allOf envelope. why.missing_must_haves items use the ABSOLUTE URN ref so a bare content sub-doc validates as a standalone root.",
      "properties": {
        "gate": {
          "const": "B"
        },
        "verdict": {
          "type": "string",
          "enum": ["pass", "fail"]
        },
        "coverage": {
          "type": "object",
          "properties": {
            "covered_ids": {
              "type": "array",
              "items": { "type": "string" }
            },
            "missing_ids": {
              "type": "array",
              "items": { "type": "string" }
            },
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "required": ["covered_ids", "missing_ids", "score"],
          "additionalProperties": false
        },
        "keyword_alignment": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "language_match": {
          "type": "boolean"
        },
        "seniority_scope_match": {
          "type": "boolean"
        },
        "why": {
          "type": "object",
          "properties": {
            "coverage": {
              "type": "string"
            },
            "missing_must_haves": {
              "type": "array",
              "items": { "$ref": "urn:give-me-job:schema:gate_result#/$defs/missing_must_have" }
            },
            "keyword_alignment": {
              "type": "number"
            },
            "language_match": {
              "type": "boolean"
            },
            "seniority_scope_match": {
              "type": "boolean"
            }
          },
          "required": ["coverage", "missing_must_haves"],
          "additionalProperties": false
        }
      },
      "required": ["gate", "verdict", "coverage", "why"],
      "additionalProperties": false
    },
    "gate_c_content": {
      "type": "object",
      "description": "Gate C (polish) advisory body. Structurally separate from Gate B: advisory const true, no verdict/exit field can exist. polish carries five integer 0-5 dimensions. Self-contained: additionalProperties:false is scoped to this object ONLY, never the allOf envelope.",
      "properties": {
        "gate": {
          "const": "C"
        },
        "advisory": {
          "const": true
        },
        "polish": {
          "type": "object",
          "properties": {
            "clarity": {
              "type": "integer",
              "minimum": 0,
              "maximum": 5
            },
            "concision": {
              "type": "integer",
              "minimum": 0,
              "maximum": 5
            },
            "formatting": {
              "type": "integer",
              "minimum": 0,
              "maximum": 5
            },
            "quantified_impact": {
              "type": "integer",
              "minimum": 0,
              "maximum": 5
            },
            "natural_keywords": {
              "type": "integer",
              "minimum": 0,
              "maximum": 5
            }
          },
          "required": ["clarity", "concision", "formatting", "quantified_impact", "natural_keywords"],
          "additionalProperties": false
        }
      },
      "required": ["gate", "advisory", "polish"],
      "additionalProperties": false
    }
  },
  "allOf": [
    { "$ref": "urn:give-me-job:schema:agent_result_v1#/$defs/envelope" }
  ],
  "properties": {
    "kind": {
      "const": "gate_result"
    },
    "schema_version": {
      "const": "1.0"
    },
    "content": {
      "oneOf": [
        { "$ref": "#/$defs/gate_a_content" },
        { "$ref": "#/$defs/gate_b_content" },
        { "$ref": "#/$defs/gate_c_content" }
      ]
    }
  },
  "required": ["kind", "schema_version"]
}
