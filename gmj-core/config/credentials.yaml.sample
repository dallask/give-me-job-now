# credential_sites — candidate credential-fetch allow-list (INGEST-02).
#
# This list authorizes candidate CREDENTIAL fetches ONLY: profile pages,
# certificate / diploma / badge pages the candidate points the analyzer at.
# It is SEPARATE from the job-board search scope in config/sources.yaml — a host
# here is NOT thereby a permitted offer-search domain, and vice versa.
#
# The gmj-sources-scope-guard hook fetch-allows a WebFetch host that is on EITHER
# this list OR sources.yaml; hosts on NEITHER stay blocked (exit 2). Every
# credential-list fetch is logged to .claude/logs/credential-intake.log.
#
# Append your own issuer hosts as full https://.../ URLs (the hook normalizes
# scheme / leading www. / path away, matching exact host or subdomain).
credential_sites:
  - https://www.linkedin.com/
  - https://www.credly.com/
  - https://coursera.org/
